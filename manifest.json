{
  "manifest_version": 3,
  "name": "Banco de Respuestas",
  "version": "0.2.0",
  "description": "Banco de respuestas cortas para responder comentarios en Instagram",
  "action": {
    "default_title": "Abrir Banco de Respuestas"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": [
    "storage",
    "clipboardWrite",
    "sidePanel"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}